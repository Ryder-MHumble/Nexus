# ─────────────────────────────────────────────────────────────────
#  Nexus — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Required fields are marked with [REQUIRED].
# ─────────────────────────────────────────────────────────────────

# ── Database [REQUIRED] ──────────────────────────────────────────
# Supabase project URL and service role key
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Crawler Settings ─────────────────────────────────────────────
# Max concurrent Playwright browser contexts (reduce if memory is limited)
PLAYWRIGHT_MAX_CONTEXTS=3
# Max concurrent HTTP crawl tasks
MAX_CONCURRENT_CRAWLS=5
# Default delay between requests in seconds (be respectful to servers)
DEFAULT_REQUEST_DELAY=1.0

# ── Pipeline Schedule (UTC) ──────────────────────────────────────
# When to run the daily data pipeline (default: 06:00 UTC)
PIPELINE_CRON_HOUR=6
PIPELINE_CRON_MINUTE=0
# Auto-trigger pipeline on first start if no data exists
STARTUP_CRAWL_ENABLED=true

# ── LLM Enrichment (optional) ───────────────────────────────────
# Enable AI-powered article enrichment in the daily pipeline
# Automatically enabled when OPENROUTER_API_KEY is set
ENABLE_LLM_ENRICHMENT=false
LLM_THRESHOLD=40

# OpenRouter API key (recommended: deepseek/deepseek-chat, $0.27/M tokens)
# Get key at: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# ── Twitter / X (optional) ──────────────────────────────────────
# Required only if you configure Twitter sources in sources/twitter.yaml
# Get API key at: https://twitterapi.io/
TWITTER_API_KEY=
# Proxy for Twitter API (if needed in your region)
TWITTER_API_PROXY=

# ── RSS Integration (optional) ───────────────────────────────────
# Self-hosted RSSHub instance for converting sites to RSS feeds
# Public instance (rsshub.app) is often rate-limited; self-hosting recommended
# See: https://docs.rsshub.app/deploy/
RSSHUB_BASE_URL=https://rsshub.app

# ── Social Media Cookies (optional) ─────────────────────────────
# Required only for sources that need authenticated access
WEIBO_COOKIE=
XIAOHONGSHU_COOKIE=

# ── API Security (optional) ──────────────────────────────────────
# Simple API key for frontend authentication (leave empty to disable auth)
API_KEY=

# ── Organization Context (optional) ──────────────────────────────
# Used in LLM prompts for policy/personnel analysis
# Customize these to match your institution's focus
ORGANIZATION_NAME=Your Organization
ORGANIZATION_FOCUS=AI research, technology policy, and talent development
